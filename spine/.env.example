# Spine environment — overrides ~/.config/lattice/config.toml when set.
# Copy to .env for local dev; in production inject via Docker/systemd.

# Path to the SQLite database file.
# Overrides spine.database_path in config.toml.
# Default (from config.toml): /var/lib/lattice/lattice.db
# Default (fallback): ./lattice.dev.db
DATABASE_PATH=./lattice.dev.db

# Bearer token for /api/agent/* routes.
# Overrides spine.agent_token in config.toml.
# Generate with: openssl rand -base64 32
LATTICE_AGENT_TOKEN=

# HTTPS is enforced by default (fail-closed). Set ALLOW_HTTP=true only for local dev.
# In production behind Caddy this must be unset or "false".
ALLOW_HTTP=true

# When set, bypasses Authelia forward-auth and injects this value as Remote-User.
# Local dev only — must be unset in production.
DEV_USER=dev@local

# Signal relay (src/signal-relay.ts)
# Your registered Signal number in E.164 format (e.g. +15551234567).
# Only messages from this number are forwarded (notes to self).
SIGNAL_PHONE_NUMBER=
# TCP address of the signal-cli JSON-RPC daemon. Defaults to 127.0.0.1:7583.
SIGNAL_RPC_HOST=127.0.0.1:7583
